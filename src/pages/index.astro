---
import Layout from "../layouts/Layout.astro";
import PostList from "../components/PostList.astro";
import Header from "../components/Header.astro";

// 載入 Markdown 文章
const postsImport = import.meta.glob("../posts/*.md", { eager: true });
const posts = Object.values(postsImport).sort(
  (a, b) =>
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime(),
);
---

<Layout>
  <Header />
  <div class="tc">
    <div class="table">
      <!-- 左 60 -->
      <div class="left-col">
        <!-- 上大 -->
        <div class="box rolling">
          <span class="text-a">無限進步</span>
          <p class="text-b">無限進步<br/>永不止步</p>
        </div>

        <!-- 下三 -->
        <div class="three-box-row">
          <div class="small-box rolling">
            <span class="text-a">A</span>
            <p class="text-b">內容A</p>
          </div>

          <div class="small-box rolling">
            <span class="text-a">B</span>
            <p class="text-b">內容B</p>
          </div>

          <div class="small-box rolling">
            <span class="text-a">C</span>
            <p class="text-b">內容C</p>
          </div>
        </div>
      </div>

      <!-- 右 40 -->
      <div class="right-col">
        <div class="box pr-photo">
          <span class="pr-text">Welcome<br><strong>kapiso's Blog</strong></span>
        </div>
      </div>
    </div>
    <PostList></PostList>
  </div>
  
</Layout>

